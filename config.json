{
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": "gemma4:31b-cloud",
      "provider": "local",
      "maxTokens": 8192,
      "contextWindowTokens": 32768,
      "temperature": 0.4,
      "maxToolIterations": 25,
      "timezone": "Europe/Brussels"
    }
  },
  "channels": {
    "sendProgress": false,
    "sendToolHints": false,
    "sendMaxRetries": 3
  },
  "providers": {
    "local": {
      "label": "Ollama (local/cloud)",
      "apiKey": "",
      "apiBase": "http://host.docker.internal:11434/v1"
    },
    "xai": {
      "label": "xAI",
      "apiKey": "",
      "apiKeyEnv": "GROK_API_KEY",
      "apiBase": "https://api.x.ai/v1",
      "models": [
        "grok-3-mini",
        "grok-3"
      ]
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 6161
  }
}
